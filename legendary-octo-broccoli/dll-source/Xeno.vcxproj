<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <Keyword>Win32Proj</Keyword>
    <RootNamespace>Xeno</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <WholeProgramOptimization>true</WholeProgramOptimization>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <!-- ── Output directories ── -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <OutDir>$(SolutionDir)bin\</OutDir>
    <IntDir>$(SolutionDir)obj\$(ProjectName)\</IntDir>
    <TargetName>Xeno</TargetName>
    <TargetExt>.dll</TargetExt>
  </PropertyGroup>

  <!-- ── Compiler settings ── -->
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <PreprocessorDefinitions>NDEBUG;WIN32;_WINDOWS;_USRDLL;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(ProjectDir)deps;$(ProjectDir)deps\Luau;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <RuntimeLibrary>MultiThreadedDLL</RuntimeLibrary>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <ExceptionHandling>Sync</ExceptionHandling>
      <WarningLevel>W3</WarningLevel>
      <SDLCheck>false</SDLCheck>
      <ConformanceMode>true</ConformanceMode>
      <!-- Silence known-safe warnings from vendored headers -->
      <DisableSpecificWarnings>4244;4267;4996;4305;4018</DisableSpecificWarnings>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <AdditionalDependencies>
        kernel32.lib;user32.lib;ole32.lib;oleaut32.lib;psapi.lib;
        advapi32.lib;comdlg32.lib;uuid.lib;%(AdditionalDependencies)
      </AdditionalDependencies>
    </Link>
    <ResourceCompile>
      <AdditionalIncludeDirectories>$(ProjectDir)deps;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ResourceCompile>
  </ItemDefinitionGroup>

  <!-- ── Source files ── -->
  <ItemGroup>
    <!-- Main DLL source -->
    <ClCompile Include="Xeno.cpp" />

    <!-- Luau compiler sources -->
    <ClCompile Include="deps\LuauSrc\Ast.cpp" />
    <ClCompile Include="deps\LuauSrc\BuiltinFolding.cpp" />
    <ClCompile Include="deps\LuauSrc\Builtins.cpp" />
    <ClCompile Include="deps\LuauSrc\BytecodeBuilder.cpp" />
    <ClCompile Include="deps\LuauSrc\Compiler.cpp" />
    <ClCompile Include="deps\LuauSrc\Confusables.cpp" />
    <ClCompile Include="deps\LuauSrc\ConstantFolding.cpp" />
    <ClCompile Include="deps\LuauSrc\CostModel.cpp" />
    <ClCompile Include="deps\LuauSrc\lcode.cpp" />
    <ClCompile Include="deps\LuauSrc\Lexer.cpp" />
    <ClCompile Include="deps\LuauSrc\Location.cpp" />
    <ClCompile Include="deps\LuauSrc\Parser.cpp" />
    <ClCompile Include="deps\LuauSrc\StringUtils.cpp" />
    <ClCompile Include="deps\LuauSrc\TableShape.cpp" />
    <ClCompile Include="deps\LuauSrc\TimeTrace.cpp" />
    <ClCompile Include="deps\LuauSrc\Types.cpp" />
    <ClCompile Include="deps\LuauSrc\ValueTracking.cpp" />

    <!-- zstd — compiled as C, not C++ -->
    <ClCompile Include="deps\zstd\zstd.c">
      <CompileAs>CompileAsC</CompileAs>
    </ClCompile>
  </ItemGroup>

  <!-- ── Header files (for IDE browsing only) ── -->
  <ItemGroup>
    <ClInclude Include="deps\Luau\Ast.h" />
    <ClInclude Include="deps\Luau\Bytecode.h" />
    <ClInclude Include="deps\Luau\BytecodeBuilder.h" />
    <ClInclude Include="deps\Luau\BytecodeUtils.h" />
    <ClInclude Include="deps\Luau\Common.h" />
    <ClInclude Include="deps\Luau\Compiler.h" />
    <ClInclude Include="deps\Luau\Confusables.h" />
    <ClInclude Include="deps\Luau\DenseHash.h" />
    <ClInclude Include="deps\Luau\ExperimentalFlags.h" />
    <ClInclude Include="deps\Luau\Lexer.h" />
    <ClInclude Include="deps\Luau\Location.h" />
    <ClInclude Include="deps\Luau\ParseOptions.h" />
    <ClInclude Include="deps\Luau\ParseResult.h" />
    <ClInclude Include="deps\Luau\Parser.h" />
    <ClInclude Include="deps\Luau\StringUtils.h" />
    <ClInclude Include="deps\Luau\TimeTrace.h" />
    <ClInclude Include="deps\Luau\Variant.h" />
    <ClInclude Include="deps\Luau\VecDeque.h" />
    <ClInclude Include="deps\base64.hpp" />
    <ClInclude Include="deps\httplib.h" />
    <ClInclude Include="deps\json.hpp" />
    <ClInclude Include="deps\luacode.h" />
    <ClInclude Include="deps\resource.h" />
    <ClInclude Include="deps\zstd\zstd.h" />
  </ItemGroup>

  <!-- ── Resource file ── -->
  <ItemGroup>
    <ResourceCompile Include="deps\Xeno.rc" />
  </ItemGroup>

  <!-- ── Other files shown in IDE ── -->
  <ItemGroup>
    <None Include="deps\client.lua" />
    <None Include="deps\zstd\README.txt" />
    <None Include="howtomake.md" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />

</Project>

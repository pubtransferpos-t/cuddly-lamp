<Window x:Class="DexeUI.HubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Execute Hub" Height="360" Width="420"
        WindowStyle="None" ResizeMode="NoResize" Background="Transparent" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bdr" BorderThickness="1" BorderBrush="Transparent" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Content" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#474747"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HubButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2E2E4A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3F3F6F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TestButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#0d2b1a"/>
            <Setter Property="Foreground" Value="#28d7a8"/>
            <Setter Property="BorderBrush" Value="#28d7a840"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1a3d28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomScrollStyle" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter Margin="0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" BorderBrush="#1a1a3a" BorderThickness="1" Background="#090912">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#0d0d1f">
                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Foreground="#a78bfa" FontSize="13" Margin="14,0,0,0"
                               VerticalAlignment="Center" FontFamily="Segoe UI Black">Dexe</TextBlock>
                    <TextBlock Foreground="#7b93b8" FontSize="13" Margin="5,0,0,0"
                               VerticalAlignment="Center" FontFamily="Segoe UI">Quick Execute Hub</TextBlock>
                </WrapPanel>
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonClose"
                        Width="28" HorizontalAlignment="Right" Margin="0,0,8,0"
                        Click="buttonClose_Click">
                    <Image Source="/Resources/Images/close2.png" Width="18" Height="18"/>
                </Button>
            </Grid>

            <Border Grid.Row="0" VerticalAlignment="Bottom" Background="#1a1a3a" Height="1"/>

            <!-- Action bar -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,8,10,4" HorizontalAlignment="Left">
                <Button Style="{StaticResource TestButtonStyle}" x:Name="buttonBasicTest"
                        Content="&#x25BA; Basic Print Test" Click="buttonBasicTest_Click" Margin="0,0,6,0"/>
                <Button Style="{StaticResource HubButtonStyle}" x:Name="buttonSaveToHub"
                        Content="+ Save Current Script" Click="buttonSaveToHub_Click"/>
            </StackPanel>

            <!-- Script list -->
            <Border Grid.Row="2" Margin="10,4,10,4" Background="#07091a"
                    BorderBrush="#1a1a3a" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <TextBlock x:Name="emptyLabel" Foreground="#3a4a6a" FontFamily="Consolas" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextAlignment="Center">
                        No saved scripts yet.&#x0a;Click "+ Save Current Script" to add one.
                    </TextBlock>
                    <ScrollViewer Style="{StaticResource CustomScrollStyle}"
                                  VerticalScrollBarVisibility="Auto" Margin="4">
                        <StackPanel x:Name="hub_container" Margin="2"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="3" Background="#0d0d1f" CornerRadius="0,0,10,10">
                <TextBlock x:Name="statusLabel" Foreground="#3a4a6a" FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center" Margin="14,0,0,0">Ready</TextBlock>
            </Border>
        </Grid>
    </Border>
</Window>
